## Required: Supabase browser client config
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

## Required in production for OAuth callback safety and canonical URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

## Optional: set false to disable article content protection
NEXT_PUBLIC_ENABLE_CONTENT_PROTECTION=true

## Optional: only for production proxy edge cases behind reverse proxy
## 0/empty = force HTTPS redirect when x-forwarded-proto is http
## 1       = disable the forced HTTPS redirect
DISABLE_FORCE_HTTPS_REDIRECT=0
