NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# 用于客户端匿名访问，受 RLS 策略保护，可安全暴露到前端

# Supabase 服务角色密钥（Service Role Key）
# 用于服务器端操作，需妥善保管，不建议暴露到前端
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# 生产环境邮件配置
NEXT_PUBLIC_SITE_URL=填写你的域名，例如：https://www.123.com

# 可选：本地使用 HTTP 时也要求 Cookie 带 Secure（部分浏览器在 http://localhost 下可能不收纳，需改 HTTPS 或移除）
# NEXT_PUBLIC_COOKIE_SECURE=true
# COOKIE_SECURE=true

